### ৩. অ্যাপ্লিকেশন চার্ট কোড (Example: `api-service`)

**`apps/api-service/templates/all-in-one.yaml`**
প্রতিটি অ্যাপের ভেতরে কোনো কোড থাকবে না, শুধু কল করা হবে।

```yaml
{{- include "common.deployment" . -}}

{{- if .Values.service.enabled }}
---
{{- include "common.service" . -}}
{{- end }}

{{- if .Values.ingress.enabled }}
---
{{- include "common.ingress" . -}}
{{- end }}

{{- if .Values.hpa.enabled }}
---
{{- include "common.hpa" . -}}
{{- end }}

{{- if .Values.pdb.enabled }}
---
{{- include "common.pdb" . -}}
{{- end }}

{{- if .Values.configmap.enabled }}
---
{{- include "common.configmap" . -}}
{{- end }}

{{- if .Values.secret.enabled }}
---
{{- include "common.secret" . -}}
{{- end }}


```

**`apps/api-service/values.yaml`**
এখানে আপনি বলে দেবেন এই অ্যাপের কী কী লাগবে।

# -------------------------
# Image & Replicas
# -------------------------
image: "my-repo/api-service:v1.2"
replicaCount: 3
imagePullPolicy: "IfNotPresent"

# -------------------------
# Pod security context
# -------------------------
podSecurityContext:
  runAsUser: 1000
  runAsGroup: 1000
  fsGroup: 2000

# -------------------------
# Node scheduling for Karpenter
# -------------------------
nodeSelector:
  karpenter.sh/capacity-type: spot
tolerations:
  - key: "karpenter.sh/not-ready"
    operator: "Exists"
    effect: "NoSchedule"

# -------------------------
# Optional: Affinity
# -------------------------
affinity: {}

# -------------------------
# Service
# -------------------------
service:
  enabled: true
  type: ClusterIP
  port: 8080

# -------------------------
# Ingress
# -------------------------
ingress:
  enabled: true
  host: "api.mydomain.com"
  class: alb

# -------------------------
# Probes
# -------------------------
probes:
  startupPath: "/healthz"
  livenessPath: "/health"
  readinessPath: "/ready"

# -------------------------
# HPA (optional)
# -------------------------
hpa:
  enabled: true
  minReplicas: 2
  maxReplicas: 10
  cpuUtilization: 50

# -------------------------
# PDB (recommended)
# -------------------------
pdb:
  enabled: true
  minAvailable: 2

# -------------------------
# Environment variables
# -------------------------
env:
  - name: ENV
    value: "production"
  - name: LOG_LEVEL
    value: "info"

envFrom:
  - configMapRef:
      name: "{{ .Release.Name }}-config"
  - secretRef:
      name: "{{ .Release.Name }}-secret"

# -------------------------
# ConfigMap (optional)
# -------------------------
configmap:
  enabled: true
  data:
    FEATURE_X_ENABLED: "true"
    FEATURE_Y_ENABLED: "false"

# -------------------------
# Secret (optional)
# -------------------------
secret:
  enabled: true
  data:
    DB_USERNAME: "myuser"
    DB_PASSWORD: "mypassword"
    API_KEY: "secret-api-key"

# -------------------------
# Resources
# -------------------------
resources:
  requests:
    cpu: 200m
    memory: 256Mi
  limits:
    cpu: 500m
    memory: 512Mi

# -------------------------
# Optional: Image pull secrets
# -------------------------
imagePullSecrets:
  - name: my-registry-secret

# -------------------------
# Optional: pod annotations
# -------------------------
podAnnotations:
  prometheus.io/scrape: "true"
  prometheus.io/port: "8080"
```

